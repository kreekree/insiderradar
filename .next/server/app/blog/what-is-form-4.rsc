0:["LunjPyf0Z1fXtraxeuOkB",[[["",{"children":["blog",{"children":["what-is-form-4",{"children":["__PAGE__",{}]}]}]},"$undefined","$undefined",true],["",{"children":["blog",{"children":["what-is-form-4",{"children":["__PAGE__",{},[["$L1",[["$","header",null,{"className":"bg-gradient-to-b from-slate-900 to-slate-950 py-10 px-4","children":["$","div",null,{"className":"max-w-3xl mx-auto","children":[["$","div",null,{"className":"font-mono text-xs text-emerald-400 border border-emerald-800 bg-emerald-950/50 px-2 py-1 rounded inline-block mb-4","children":"FORM 4"}],["$","h1",null,{"className":"text-3xl md:text-4xl font-extrabold text-white mb-3","children":"What Is SEC Form 4? A Complete Guide for Retail Investors"}],["$","p",null,{"className":"text-slate-500 text-sm font-mono","children":"Published March 15, 2026"}]]}]}],["$","main",null,{"className":"max-w-3xl mx-auto px-4 py-10 prose prose-invert prose-slate max-w-none","children":[["$","div",null,{"id":"ezoic-pub-ad-placeholder-102","className":"mb-8 not-prose"}],["$","p",null,{"className":"text-slate-400 leading-relaxed mb-6","children":"SEC Form 4 is one of the most powerful — and least understood — public documents in the US financial system. It's free. It's public. It's filed within 48 hours of every insider transaction. And most retail investors have never looked at one."}],["$","h2",null,{"className":"text-2xl font-bold text-white mt-8 mb-4","children":"What Is Form 4?"}],["$","p",null,{"className":"text-slate-400 leading-relaxed mb-4","children":"Form 4 is a disclosure document filed with the US Securities and Exchange Commission under Section 16(a) of the Securities Exchange Act of 1934. It must be filed by any corporate insider — defined as an officer, director, or beneficial owner of more than 10% of a company's equity securities — within two business days of any transaction involving that company's stock."}],["$","p",null,{"className":"text-slate-400 leading-relaxed mb-4","children":"The filing captures the who, what, when, and how much of every insider trade. It's publicly available on the SEC's EDGAR database the moment it's accepted — usually within hours of filing."}],["$","h2",null,{"className":"text-2xl font-bold text-white mt-8 mb-4","children":"Who Has to File Form 4?"}],["$","ul",null,{"className":"text-slate-400 space-y-2 mb-6 list-disc pl-6","children":[["$","li",null,{"children":"Chief Executive Officers (CEOs)"}],["$","li",null,{"children":"Chief Financial Officers (CFOs) and other C-suite officers"}],["$","li",null,{"children":"Board of Directors members"}],["$","li",null,{"children":"Shareholders owning more than 10% of any class of equity securities"}]]}],["$","h2",null,{"className":"text-2xl font-bold text-white mt-8 mb-4","children":"Why Does This Matter to You?"}],["$","p",null,{"className":"text-slate-400 leading-relaxed mb-4","children":"When a CEO buys $2 million of their own company's stock in the open market, they're making a statement. They know the product roadmap. They know the next earnings report is coming. They know what deals are in the pipeline. And they decided — with their own money, at market price — that the stock is worth buying right now."}],["$","p",null,{"className":"text-slate-400 leading-relaxed mb-4","children":"Academic research published in the Journal of Financial Economics has consistently shown that clusters of insider buying — particularly by high-ranking officers making large open-market purchases — tend to precede positive stock returns over 6-12 month horizons. This is not a secret. Hedge fund compliance desks monitor Form 4 filings daily. Now you can too."}],["$","h2",null,{"className":"text-2xl font-bold text-white mt-8 mb-4","children":"The Signal vs. The Noise"}],["$","p",null,{"className":"text-slate-400 leading-relaxed mb-4","children":["Not all Form 4 transactions are created equal. The one you care about is transaction code ",["$","strong",null,{"className":"text-white","children":"P — open-market purchase"}],". Everything else is largely noise:"]}],["$","ul",null,{"className":"text-slate-400 space-y-2 mb-6 list-disc pl-6","children":[["$","li",null,{"children":[["$","strong",null,{"className":"text-white","children":"A (Award)"}]," — shares granted as compensation. The insider paid nothing. Zero signal."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white","children":"M (Option Exercise)"}]," — converting options to shares. Usually followed immediately by a sale. Neutral to slightly negative."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white","children":"F (Tax Withholding)"}]," — automatic. Not a decision. Ignore it."]}],["$","li",null,{"children":[["$","strong",null,{"className":"text-white","children":"S (Sale)"}]," — worth noting, but context matters enormously. Insiders sell for many reasons unrelated to their view of the stock."]}]]}],["$","div",null,{"className":"bg-slate-900 border border-slate-800 rounded-xl p-5 my-8 not-prose","children":[["$","p",null,{"className":"text-slate-300 text-sm font-semibold mb-2","children":"The bottom line:"}],["$","p",null,{"className":"text-slate-400 text-sm","children":"An insider buy (code P) is a deliberate, voluntary decision to spend personal cash at whatever the market is offering. An insider sell could mean anything. Focus your attention accordingly."}]]}],["$","p",null,{"className":"text-slate-400 leading-relaxed","children":["InsiderRadar surfaces Form 4 data directly from SEC EDGAR in real time. ",["$","a",null,{"href":"/","className":"text-emerald-400 hover:underline","children":"Search any US stock ticker"}]," to see the latest insider transactions — or check the ",["$","a",null,{"href":"/unusual-activity","className":"text-emerald-400 hover:underline","children":"unusual activity feed"}]," for the largest open-market purchases across all companies in the last 30 days."]}],["$","div",null,{"className":"mt-10 not-prose flex flex-wrap gap-3","children":[["$","a",null,{"href":"/","className":"bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-semibold px-4 py-2 rounded-lg text-sm transition","children":"Search Insider Trades →"}],["$","a",null,{"href":"/how-to-read-form4-13f","className":"bg-slate-800 hover:bg-slate-700 text-white px-4 py-2 rounded-lg text-sm transition","children":"Full Reading Guide →"}]]}]]}],["$","div",null,{"className":"max-w-3xl mx-auto px-4 pb-4","children":["$","div",null,{"id":"ezoic-pub-ad-placeholder-103"}]}]]],null],null]},["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","blog","children","what-is-form-4","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined","styles":null}],null]},["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children","blog","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined","styles":null}],null]},[["$","html",null,{"lang":"en","className":"__variable_3c557b","children":[["$","head",null,{"children":["$","script",null,{"src":"//www.ezojs.com/ezoic/sa.min.js","async":true}]}],["$","body",null,{"children":[["$","$L4",null,{}],["$","$L2",null,{"parallelRouterKey":"children","segmentPath":["children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L3",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":[["$","title",null,{"children":"404: This page could not be found."}],["$","div",null,{"style":{"fontFamily":"system-ui,\"Segoe UI\",Roboto,Helvetica,Arial,sans-serif,\"Apple Color Emoji\",\"Segoe UI Emoji\"","height":"100vh","textAlign":"center","display":"flex","flexDirection":"column","alignItems":"center","j